                                <asp:DropDownList ID="ddlTrips" runat="server"
                                    OnSelectedIndexChanged="ddlTrips_SelectedIndexChanged"
                                    AutoPostBack="true"
                                    CssClass="form-select">
                                    <asp:ListItem Text="-- Select Trip --" Value="0"></asp:ListItem>
                                </asp:DropDownList>
                            </div>
                        </li>--%>

                        <li class="menu-dropdown">
                            <a href="javascript:void(0);" class="dropdown-toggle">Booking 
                            </a>
                            <ul class="submenu">
                                <li><a href="ticket.aspx">Buy Ticket</a></li>
                                <li><a href="Booked_ticket.aspx">Booking History</a></li>
                            </ul>
                        </li>


                       <%-- <li><a runat="server" href="~/Support.aspx">Support Ticket</a></li>--%>
                        <li>
                            <a href="javascript::void()">Profile</a>
                            <ul class="sub-menu">
                                <li><a href="~/MyBookings.aspx" runat="server">MyBookings</a></li>
                                <li><a href="#">Wallet</a></li>
                                <li><a href="~/Profile.aspx" runat="server">Profile</a></li>
                                <li><a href="~/modifyPassword.aspx" runat="server">Change Password</a></li>
                                <li>
                                    <asp:LinkButton ID="btnLogout" runat="server" OnClick="btnLogout_Click">Logout</asp:LinkButton>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="body-content">
            <asp:ContentPlaceHolder ID="MainContent" runat="server" />
        </div>

        <!-- Footer -->
        <footer class="text-center mt-5">
            <%--<p>&copy; <%: DateTime.Now.Year %> - ExcelBus</p>--%>
        </footer>
    </form>

    <!-- Scripts -->
    <script src="js/bootstrap.bundle.min.js"></script>
    <script src="js/jquery-3.7.1.min.js"></script>
    <%--<script src="https://excelbus.mavenxone.com/assets/global/js/jquery.min.js"></script>
    <script src="https://excelbus.mavenxone.com/assets/global/js/bootstrap.bundle.min.js"></script>--%>
    <asp:ContentPlaceHolder ID="ScriptsContent" runat="server" />

    <!-- Footer Section Starts Here -->
    <section class="footer-section">
        <div class="footer-top">
            <div class="container">
                <div class="row footer-wrapper gy-sm-5 gy-4">
                    <div class="col-xl-4 col-lg-3 col-md-6 col-sm-6">
                        <div class="footer-widget">
                            <div class="logo">
                                <img src="img/excel_bus_logo.png" alt="Logo">
                            </div>
                            <p>Delectus culpa laboriosam debitis saepe. Commodi earum minus ut obcaecati veniam deserunt est!</p>
                            <ul class="social-icons">
                                <li>
                                    <a href="https://www.facebook.com/"><i class="lab la-facebook-f"></i></a>
