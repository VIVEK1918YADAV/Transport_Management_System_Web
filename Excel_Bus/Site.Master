                                        href="mailto:rajesh.paul@excelgeomatics.com">rajesh.paul@excelgeomatics.com</a>
                                </li>
                            </ul>
                            <div class="customBtn">
                                <a  href="Admin/Admin.aspx" target="_blank" class="intraCityBtn">Intra City</a>
                                <a href="http://180.151.15.18:9008/InterCityBus/index"target="_blank" class="interCityBtn">Inter City</a>
                            </div>
                        </div>
