                </div>
            </div>
        </div>
    </section>
    <style>
        .menu-dropdown {
            position: relative;
        }
            .menu-dropdown .submenu {
                display: none; /* hidden by default */
                list-style: none;
                padding-left: 0;
                margin: 5px 0 0 0;
                background: #fff;
                position: absolute;
                left: 0;
                min-width: 180px;
                box-shadow: 0 4px 8px rgba(0,0,0,0.1);
                z-index: 1000;
            }

                .menu-dropdown .submenu li a {
                    display: block;
                    padding: 8px 12px;
                    text-decoration: none;
                    color: #333;
                }

                    .menu-dropdown .submenu li a:hover {
                        background-color: #f0f0f0;
                    }
            /* Show submenu when hovering the parent link */
            .menu-dropdown:hover .submenu,
            .menu-dropdown:focus-within .submenu {
                display: block;
            }
    </style>


</body>
</html>
