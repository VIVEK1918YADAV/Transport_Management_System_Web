<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="TrainAdminMaster.Master.cs" Inherits="Excel_Bus.TrainAdminMaster" %>

<!DOCTYPE html>
<html lang="en">
<head runat="server">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ExcelTrain - Dashboard</title>

    <link rel="shortcut icon" type="image/png" href="~/assets/images/logo_icon/favicon.png">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/assets/global/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/assets/admin/css/vendor/bootstrap-toggle.min.css">
    <link rel="stylesheet" href="~/assets/global/css/all.min.css">
    <link rel="stylesheet" href="~/assets/global/css/line-awesome.min.css">
    <link rel="stylesheet" type="text/css" href="~/assets/global/css/daterangepicker.css">
    <link rel="stylesheet" href="~/assets/global/css/select2.min.css">
    <link rel="stylesheet" href="~/assets/admin/css/app.css">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        :root {
            --main-blue: #1e3c72;
            --main-blue-light: #2a5298;
            --submenu-bg: #142850;
            --active-yellow: #ffd500;
            --hover-blue: #264e9a;
            --divider: rgb(239 240 245);
            --text-white: #fff;
            --font: 'Poppins', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--font);
            background: #47a17b;
        }

        .daterangepicker.ltr.show-ranges.opensright {
            display: none !important;
        }

        /* Sidebar */
        .sidebar {
            width: 250px;
            height: 100vh;
            background: #47a17b;
            position: fixed;
            top: 0;
            left: 0;
            color: var(--text-white);
            overflow-y: auto;
            transition: all 0.3s ease;
            font-family: var(--font);
            box-shadow: 3px 0 10px rgb(132 205 130 / 67%);
            display: flex;
            flex-direction: column;
            z-index: 1000;
        }

        .sidebar-hidden {
            left: -250px !important;
        }

        .sidebar__inner {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .sidebar__logo {
            padding: 7px 10px;
            text-align: center;
            border-bottom: 1px solid var(--divider);
            background-color: #2d9b8b8a;
        }

            .sidebar__logo img {
                width: 80px;
                height: 80px;
                object-fit: contain;
                border-radius: 50%;
            }

            .sidebar__logo h3 {
                color: #333;
                font-size: 16px;
                margin-top: 8px;
                font-weight: 600;
            }

        .sidebar__menu-wrapper {
            flex-grow: 1;
            padding-top: 15px;
        }

        .sidebar__menu {
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .sidebar-menu-item {
            position: relative;
            text-align: center;
        }

            .sidebar-menu-item::after {
                content: "";
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 1px;
                background-color: #2d9b8b8a;
            }

            .sidebar-menu-item > a {
                display: flex;
                flex-direction: column;
                align-items: center;
                text-decoration: none;
                color: var(--text-white);
                padding: 15px;
                transition: all 0.3s ease;
            }

                .sidebar-menu-item > a i.menu-icon {
                    font-size: 22px;
                    margin-bottom: 4px;
                }

                .sidebar-menu-item > a:hover {
                    background-color: #2d9b8b8a;
                }

            .sidebar-menu-item.active > a {
                background-color: #2d9b8b8a;
                color: #000;
                font-weight: 600;
            }

        .sidebar-submenu {
            background-color: #2d9b8b8a;
            display: none;
            border-top: 1px solid var(--divider);
            border-bottom: 1px solid var(--divider);
        }

        .sidebar-menu-item.active .sidebar-submenu {
            display: block;
        }

        .sidebar-submenu ul {
            list-style: none;
            margin: 0;
            padding: 0;
        }

            .sidebar-submenu ul li a {
                display: block;
                padding: 10px 15px;
                color: #ddd;
                text-decoration: none;
                font-size: 14px;
                transition: all 0.3s ease;
            }

                .sidebar-submenu ul li a:hover {
                    color: #fff;
                    background-color: #2d9b8b8a;
                }

            .sidebar-submenu ul li.active a {
                background-color: #2d9b8b8a;
                color: #fff;
            }

        .sidebar::-webkit-scrollbar {
            width: 6px;
        }

        .sidebar::-webkit-scrollbar-thumb {
            background: #47a17b;
            border-radius: 10px;
        }

        /* Page Wrapper */
        .page-wrapper {
            margin-left: 250px;
            background: #c2efdc;
            min-height: 100vh;
            transition: all 0.3s ease;
        }

        .page-wrapper.full-width {
            margin-left: 0 !important;
        }

        /* Navbar */
        .navbar-wrapper {
            height: 76px;
            background: #47a17b;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 25px;
            box-shadow: 2px 7px 6px rgb(159 235 122 / 39%);
        }

        /* FIX: Toggle button kabhi hide na ho */
        .navbar-left {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-shrink: 0;
            min-width: 50px;
            overflow: hidden;
        }

        #toggleSidebar {
            display: inline-flex !important;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            flex-shrink: 0;
            width: 36px;
            height: 36px;
        }

        #moduleBreadcrumb {
            background: #2d9b8b;
            padding: 6px 14px;
            border-radius: 5px;
            overflow: hidden;
            max-width: 55vw;
            white-space: nowrap;
            text-overflow: ellipsis;
            flex-shrink: 1;
        }

        .body-wrapper {
            padding: 25px;
        }

        .navbar__right ul {
            display: flex;
            align-items: center;
            gap: 25px;
            margin: 0;
            padding: 0;
            list-style: none;
        }

        .notification-bell {
            position: relative;
            cursor: pointer;
        }

            .notification-bell img {
                width: 24px;
                height: 24px;
            }

            .notification-bell:hover img {
                transform: scale(1.1);
                transition: transform 0.2s ease;
            }

        .badge.bg-warning {
            background-color: #2d9b8b8a !important;
            color: #000 !important;
            font-weight: 600;
            border-radius: 50%;
            padding: 3px 7px;
        }

        .profile-dropdown button {
            background: transparent;
            border: none;
            cursor: pointer;
        }

        .navbar-user__thumb img {
            border-radius: 50%;
            border: 2px solid #fff;
        }

        .dropdown-menu__item:hover {
            background-color: #2d9b8b8a;
        }

        /* Mobile */
        @media (max-width: 768px) {
            .sidebar {
                left: -250px;
            }

                .sidebar.open {
                    left: 0;
                }

            .page-wrapper {
                margin-left: 0;
            }

            .navbar-wrapper {
                left: 0;
            }

            #moduleBreadcrumb {
                max-width: 35vw;
            }
        }
    </style>

    <asp:ContentPlaceHolder ID="head" runat="server">
    </asp:ContentPlaceHolder>
</head>
