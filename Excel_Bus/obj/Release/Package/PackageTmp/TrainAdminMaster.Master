    <script>
        document.addEventListener("click", function (e) {
            const toggle = document.getElementById("notificationToggle");
            const menu = toggle?.nextElementSibling;
            if (!menu) return;
            if (toggle.contains(e.target)) {
                menu.classList.toggle("show");
            } else if (!menu.contains(e.target)) {
                menu.classList.remove("show");
            }
        });
    </script>

    <script src="<%= ResolveUrl("~/assets/global/js/jquery-3.7.1.min.js") %>"></script>
    <script src="<%= ResolveUrl("~/assets/global/js/bootstrap.bundle.min.js") %>"></script>
    <script src="<%= ResolveUrl("~/assets/admin/js/vendor/bootstrap-toggle.min.js") %>"></script>

    <link href="<%= ResolveUrl("~/assets/global/css/iziToast.min.css") %>" rel="stylesheet">
    <link href="<%= ResolveUrl("~/assets/global/css/iziToast_custom.css") %>" rel="stylesheet">
    <script src="<%= ResolveUrl("~/assets/global/js/iziToast.min.js") %>"></script>

    <script>
        "use strict";
        const colors = {
            success: '#28c76f',
            error: '#eb2222',
            warning: '#ff9f43',
            info: '#1e9ff2',
        }
        const icons = {
            success: 'fas fa-check-circle',
            error: 'fas fa-times-circle',
            warning: 'fas fa-exclamation-triangle',
            info: 'fas fa-exclamation-circle',
        }
        const triggerToaster = (status, message) => {
            iziToast[status]({
                title: status.charAt(0).toUpperCase() + status.slice(1),
                message: message,
                position: "topRight",
                backgroundColor: '#fff',
                icon: icons[status],
                iconColor: colors[status],
                progressBarColor: colors[status],
                titleSize: '1rem',
                messageSize: '1rem',
                titleColor: '#474747',
                messageColor: '#a2a2a2',
                transitionIn: 'obunceInLeft'
            });
        }
        function notify(status, message) {
            if (typeof message == 'string') {
                triggerToaster(status, message);
            } else {
                $.each(message, (i, val) => triggerToaster(status, val));
            }
        }
    </script>

    <script src="<%= ResolveUrl("~/assets/global/js/nicEdit.js") %>"></script>
    <script src="<%= ResolveUrl("~/assets/global/js/select2.min.js") %>"></script>
    <script src="<%= ResolveUrl("~/assets/admin/js/app.js") %>"></script>

    <script type="text/javascript">
        function googleTranslateElementInit() {
            new google.translate.TranslateElement({
                pageLanguage: 'en',
                includedLanguages: 'fr',
                layout: google.translate.TranslateElement.InlineLayout.SIMPLE
            }, 'google_translate_element');
        }
        function autoTranslateToFrench() {
            const interval = setInterval(() => {
                const select = document.querySelector('.goog-te-combo');
                if (select) {
                    select.value = 'fr';
                    select.dispatchEvent(new Event('change'));
                    clearInterval(interval);
                }
            }, 500);
        }
        window.addEventListener('load', () => {
            autoTranslateToFrench();
        });
    </script>

    <script src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>

    <script>
        "use strict";
        bkLib.onDomLoaded(function () {
            $(".nicEdit").each(function (index) {
                $(this).attr("id", "nicEditor" + index);
                new nicEditor({ fullPanel: true }).panelInstance('nicEditor' + index, { hasPanel: true });
            });
        });
        (function ($) {
            $(document).on('mouseover', '.nicEdit-main,.nicEdit-panelContain', function () {
                $('.nicEdit-main').focus();
            });
            $('.breadcrumb-nav-open').on('click', function () {
                $(this).toggleClass('active');
                $('.breadcrumb-nav').toggleClass('active');
            });
            $('.breadcrumb-nav-close').on('click', function () {
                $('.breadcrumb-nav').removeClass('active');
            });
            if ($('.topTap').length) {
                $('.breadcrumb-nav-open').removeClass('d-none');
            }
        })(jQuery);
    </script>

    <script>
        if ($('li').hasClass('active')) {
            $('.sidebar__menu-wrapper').animate({
                scrollTop: eval($(".active").offset().top - 320)
            }, 500);
        }
    </script>

    <script>
        function toggleDetails(btn) {
            const row = btn.parentNode;
            const nextRow = row.nextElementSibling;
            if (nextRow.classList.contains('details')) {
                const isVisible = nextRow.style.display === 'table-row';
                nextRow.style.display = isVisible ? 'none' : 'table-row';
                btn.textContent = isVisible ? '➕' : '➖';
            }
        }
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const breadcrumb = document.getElementById("moduleBreadcrumb");
            const modSpan = document.getElementById("breadcrumbModule");
            const arrowSpan = document.getElementById("breadcrumbArrow");
            const subSpan = document.getElementById("breadcrumbSub");

            // ---- Breadcrumb restore from localStorage ----
            const savedModule = localStorage.getItem("breadcrumbModule");
            const savedSub = localStorage.getItem("breadcrumbSub");

            if (savedModule) {
                modSpan.textContent = savedModule;
                breadcrumb.style.display = "block";
                if (savedSub) {
                    arrowSpan.style.display = "inline";
                    subSpan.textContent = savedSub;
                } else {
                    arrowSpan.style.display = "none";
                    subSpan.textContent = "";
                }
            }

            // ---- Sidebar active menu restore from localStorage ----
            const savedMenu = localStorage.getItem("activeTrainMenu");
            if (savedMenu) {
                document.querySelectorAll(".sidebar-dropdown").forEach(function (drop) {
                    if (drop.id === savedMenu) {
                        drop.classList.add("active");
                    }
                });
            }

            // ---- Toggle Sidebar — FIX: state localStorage mein save hoti hai ----
            const toggleBtn = document.getElementById("toggleSidebar");
            const sidebar = document.querySelector(".sidebar");
            const pageWrapper = document.querySelector(".page-wrapper");

            // Page load pe sidebar hidden state restore karo
            const sidebarHidden = localStorage.getItem("sidebarHidden") === "true";
            if (sidebarHidden) {
                sidebar.classList.add("sidebar-hidden");
                pageWrapper.classList.add("full-width");
            }

            toggleBtn.addEventListener("click", function () {
                sidebar.classList.toggle("sidebar-hidden");
                pageWrapper.classList.toggle("full-width");
                // Naya state localStorage mein save karo
                const isNowHidden = sidebar.classList.contains("sidebar-hidden");
                localStorage.setItem("sidebarHidden", isNowHidden);
            });

            // ---- Parent menu click ----
            document.querySelectorAll(".sidebar-dropdown > a").forEach(function (toggle) {
                toggle.addEventListener("click", function () {
                    const parent = this.parentElement;
                    const isActive = parent.classList.contains("active");

                    // Sab close karo
                    document.querySelectorAll(".sidebar-dropdown").forEach(function (drop) {
                        drop.classList.remove("active");
                    });

                    if (!isActive) {
                        parent.classList.add("active");
                        localStorage.setItem("activeTrainMenu", parent.id);

                        // Breadcrumb - module name
                        const moduleName = this.querySelector(".menu-title")?.textContent.trim() || "";
                        modSpan.textContent = moduleName;
                        arrowSpan.style.display = "none";
                        subSpan.textContent = "";
                        breadcrumb.style.display = "block";
                        localStorage.setItem("breadcrumbModule", moduleName);
                        localStorage.removeItem("breadcrumbSub");
                    } else {
                        localStorage.removeItem("activeTrainMenu");
                    }
                });
            });

            // ---- Submenu link click ----
            document.querySelectorAll(".sidebar-submenu a.nav-link").forEach(function (link) {
                link.addEventListener("click", function () {
                    const dropParent = this.closest(".sidebar-dropdown");
                    if (dropParent) {
                        localStorage.setItem("activeTrainMenu", dropParent.id);
                    }
                    const subName = this.querySelector(".menu-title")?.textContent.trim() || "";
                    arrowSpan.style.display = "inline";
                    subSpan.textContent = subName;
                    breadcrumb.style.display = "block";
                    localStorage.setItem("breadcrumbSub", subName);
                });
            });

        });
    </script>  <asp:ContentPlaceHolder ID="scripts" runat="server">
    </asp:ContentPlaceHolder>
</body>
</html>
